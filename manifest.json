{
  "manifest_version": 3,
  "name": "Synapse Meeting Copilot",
  "version": "1.0",
  "description": "AI Meeting Copilot to automate Todoist task creation and summary emails.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.todoist.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Synapse Copilot"
  }
}
